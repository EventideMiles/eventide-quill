{
	"name": "eventide-quill",
	"version": "0.1.0",
	"description": "A feedback-first, novelist-focused writing assistant for Obsidian.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "prettier --write 'src/**/*.ts' && tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix && prettier --write 'src/**/*.ts'",
		"prettier:check": "prettier --check 'src/**/*.ts'",
		"prettier:fix": "prettier --write 'src/**/*.ts'"
	},
	"keywords": [],
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@types/node": "^22.15.17",
		"esbuild": "^0.28.1",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "^0.3.0",
		"globals": "^17.6.0",
		"jiti": "^2.6.1",
		"obsidian": "latest",
		"prettier": "^3.8.4",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.59.1"
	},
	"dependencies": {
		"@codemirror/state": "6.5.0",
		"@codemirror/view": "6.38.6"
	}
}
