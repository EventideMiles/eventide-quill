# planning
.planning/

# local agent overrides (per-developer, environment-specific)
.local/

# vscode
.vscode 

# Intellij
*.iml
.idea

# npm
node_modules

# Don't include the compiled main.js file in the repo.
# They should be uploaded to GitHub releases instead.
main.js

# Don't include the compiled styles.css (built from styles/main.scss by sass).
# Same release-artifact pattern as main.js.
styles.css

# Exclude sourcemaps
*.map

# obsidian
data.json

# Dashboard snapshot runtime data (pluginDataDir output)
dashboards/

# Exclude macOS Finder (System Explorer) View States
.DS_Store
